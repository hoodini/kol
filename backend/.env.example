# Blitz AI - Transcription Studio Configuration
# Copy this file: cp .env.example .env
# Then fill in your API keys below.

# Groq API (Whisper v3) - https://console.groq.com
GROQ_API_KEY=

# Google Gemini API - https://aistudio.google.com/apikey
GEMINI_API_KEY=

# HuggingFace API (ivrit-ai) - https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# Default transcription engine: local | groq | gemini | huggingface
DEFAULT_ENGINE=local

# Default language (ISO 639-1)
DEFAULT_LANGUAGE=he

# Server settings
HOST=127.0.0.1
PORT=8000
